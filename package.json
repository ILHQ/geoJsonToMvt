{
  "name": "@deepinnet/geojson-to-mvt",
  "version": "0.0.1",
  "description": "Convert GeoJSON FeatureCollection data to 2D MVT or custom 3D protobuf tiles",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./3d-codec": "./src/3d/index.js"
  },
  "scripts": {
    "generate-tiles:2d": "node index.2d.js",
    "generate-tiles:3d": "node index.3d.js",
    "preview": "node ./scripts/preview-server.js"
  },
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "geojson-vt": "^4.0.2",
    "vt-pbf": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
